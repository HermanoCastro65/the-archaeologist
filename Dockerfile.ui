# ============================================================
# Docker container to build and run The Archaeologist UI
#
# Build:
# docker build -f Dockerfile.ui -t archaeologist-ui .
#
# Run:
# docker run -it archaeologist-ui
# ============================================================

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    git \
    python3 \
    python3-pip \
    python3-tk \
    xvfb \
    curl \
    sed \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . .

# Fix CRLF issues from Windows
RUN sed -i 's/\r$//' build.sh
RUN sed -i 's/\r$//' entrypoint.sh

RUN chmod +x build.sh
RUN chmod +x entrypoint.sh

# Build C++ engine and bindings
RUN ./build.sh

CMD ["bash", "./entrypoint.sh"]