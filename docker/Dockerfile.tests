# ============================================================
# Para usar este container no PowerShell rode:
#
# Build:
# docker build -f docker/Dockerfile.tests -t archaeologist-tests .
#
# Run:
# docker run --rm archaeologist-tests
#
# ============================================================

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    ninja-build \
    git \
    python3 \
    python3-pip \
    curl \
    sed \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY . /app
# Remove CRLF if files were created on Windows
RUN sed -i 's/\r$//' scripts/build.sh

RUN chmod +x scripts/build.sh

CMD ["bash", "scripts/build.sh"]